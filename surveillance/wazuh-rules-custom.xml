<group name="sainte-claire,authentication,">

  <rule id="100001" level="10" frequency="5" timeframe="120">
    <if_matched_sid>18152</if_matched_sid>
    <same_source_ip/>
    <description>Sainte-Claire - Bruteforce AD : 5 echecs en 2 minutes</description>
    <group>authentication_failures,gdpr_IV_35.7.d,</group>
  </rule>

  <rule id="100002" level="12">
    <if_sid>18152</if_sid>
    <time>20:00 - 07:00</time>
    <description>Sainte-Claire - Connexion AD hors horaires</description>
    <group>policy_violation,gdpr_IV_32.2,</group>
  </rule>

  <rule id="100003" level="14">
    <if_sid>18145</if_sid>
    <match>Mediboard</match>
    <user>^(?!dr\.|inf\.)</user>
    <description>Sainte-Claire - Acces Mediboard compte non medical</description>
    <group>unauthorized_access,gdpr_IV_32.2,</group>
  </rule>

  <rule id="100004" level="13">
    <if_sid>5902</if_sid>
    <match>Domain Admins</match>
    <description>Sainte-Claire - Modification du groupe Domain Admins</description>
    <group>privilege_escalation,gdpr_IV_35.7.d,</group>
  </rule>

</group>
